{
	"name": "twitter-api-safe-proxy-workspace",
	"version": "1.0.0",
	"description": "Workspace for twitter-api-safe-proxy packages.",
	"private": true,
	"type": "module",
	"scripts": {
		"dev:proxy": "pnpm --filter twitter-api-safe-proxy dev",
		"build:proxy": "pnpm --filter twitter-api-safe-proxy build",
		"start:proxy": "pnpm --filter twitter-api-safe-proxy start",
		"test:proxy": "pnpm --filter twitter-api-safe-request test",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"type-check": "pnpm --filter twitter-api-safe-request type-check && pnpm --filter twitter-api-safe-proxy type-check"
	},
	"keywords": [
		"typescript",
		"playwright",
		"automation"
	],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@types/node": "^25.0.2",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@9.15.0"
}
