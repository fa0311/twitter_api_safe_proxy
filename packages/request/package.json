{
	"name": "twitter-api-safe-request",
	"version": "0.0.1",
	"description": "Safe request helpers for Twitter/X web API access through a Playwright profile.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"injects",
		"README.md"
	],
	"scripts": {
		"clean": "rimraf dist",
		"build": "pnpm clean && tsc -p tsconfig.json",
		"prepack": "pnpm build",
		"test": "vitest run",
		"type-check": "tsc -p tsconfig.json --noEmit"
	},
	"keywords": [
		"twitter",
		"x",
		"playwright",
		"api"
	],
	"author": "",
	"license": "MIT",
	"peerDependencies": {
		"playwright": ">=1.57.0 <2"
	},
	"devDependencies": {
		"@twitter-api-safe/test-utils": "workspace:*",
		"@types/node": "^25.0.2",
		"playwright": "^1.57.0",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	}
}
