{
	"name": "twitter-api-safe-proxy",
	"version": "1.0.0",
	"description": "HTTP proxy server for safe Twitter/X web API requests through Playwright profiles.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"bin": {
		"twitter-api-safe-proxy": "dist/server.js",
		"twitter-api-safe-debug": "dist/dashboard/server.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"predev": "pnpm --filter twitter-api-safe-request build",
		"dev": "tsx watch src/server.ts",
		"dev:debug": "tsx watch src/dashboard/server.ts",
		"prebuild": "pnpm --filter twitter-api-safe-request build",
		"build": "tsc -p tsconfig.json",
		"prepack": "pnpm build",
		"start": "node dist/server.js",
		"start:debug": "node dist/dashboard/server.js",
		"test": "vitest run",
		"pretype-check": "pnpm --filter twitter-api-safe-request build",
		"type-check": "tsc -p tsconfig.json --noEmit"
	},
	"keywords": [
		"twitter",
		"x",
		"hono",
		"playwright",
		"proxy"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@hono/node-server": "^1.19.4",
		"hono": "^4.11.0",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.57.0",
		"twitter-api-safe-request": "workspace:*",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@twitter-api-safe/test-utils": "workspace:*",
		"@types/node": "^25.0.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	}
}
