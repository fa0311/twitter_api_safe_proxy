		"react-dom": "^19.2.6",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^25.0.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"vite": "^8.0.11"
	}
}
