{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"noEmit": true,
		"types": ["node", "vite/client"]
	},
	"include": ["src/ui/**/*", "vite.config.ts"],
	"exclude": ["node_modules", "dist"]
}
